CREATE TABLE document_type (id bigint(19) NOT NULL AUTO_INCREMENT comment 'NUMERO IDENTIFICADOR DE CADA UNO DE LOS TIPOS DE DOCUMENTOS EXISTENTES', name varchar(30) NOT NULL comment 'NOMBRE DE CADA UNO DE LOS TIPOS DE DOCUMENTOS', abbreviation varchar(7) NOT NULL, PRIMARY KEY (id)) comment='Contiene cada tipo de documento existente';
CREATE TABLE neighborhood (id bigint(19) NOT NULL AUTO_INCREMENT comment 'NUMERO IDENTIFICADOR DE CADA UNO DE LOS BARRIOS DE BOGOTA', id_locality bigint(19) NOT NULL, name varchar(20) NOT NULL comment 'NOMBRE DE CADA UNO DE LOS BARRIOS EN BOGOTA', PRIMARY KEY (id)) comment='CONTIENE CADA UNO DE LOS BARRIOS DE LA CIUDAD DE BOGOTÁ';
CREATE TABLE employee (id bigint(19) NOT NULL AUTO_INCREMENT comment 'LLave primaria de la tabla', document_type bigint(19) NOT NULL comment 'CODIGO CON EL TIPO DE DOCUMENTO DEL VETERINARIO', id_veterinary bigint(19) NOT NULL, id_user bigint(19) NOT NULL, document_number varchar(255) NOT NULL comment 'NUMERO DE DOCUMENTO DE CADA UNO DE LOS VETERINARIOS REGISTRADOS', PRIMARY KEY (id)) comment='CONTIENE CADA UNO DE LOS VETERINARIOS QUE SE HAN EMPLEADO EN LAS VETERINARIAS';
CREATE TABLE veterinary_clinic (id bigint(19) NOT NULL AUTO_INCREMENT, id_barrio bigint(19) NOT NULL comment 'CODIGO IDENTIFICADOR DEL BARRIO EN DONDE SE ENCUENTRA LA VETERINARIA', id_document_type bigint(19) NOT NULL, nit varchar(12) NOT NULL comment 'CODIGO IDENTIFICADOR DE LA VETERINARIA', name varchar(40) NOT NULL comment 'NOMBRE DE LA VETERINARIA', address varchar(250) NOT NULL, phone varchar(10) NOT NULL UNIQUE comment 'TELEFONO DE LA VETERINARIA', email varchar(100) NOT NULL UNIQUE, PRIMARY KEY (id)) comment='CONTIENE LA INFORMACION DE CADA UNA DE LAS VETERINARIAS ALIADAS.';
CREATE TABLE race (id bigint(19) NOT NULL AUTO_INCREMENT comment 'NUMERO IDENTIFICADOR DE CADA UNA DE LAS RAZAS EXISTENTES A LAS QUE SE LES PRESTA ATENCION EN LAS VETERINARIAS', id_species bigint(19) NOT NULL, name varchar(30) NOT NULL comment 'CONTIENE EL NOMBRE DE LA RAZA', PRIMARY KEY (id)) comment='CONTIENE CADA UNA DE LAS RAZAS A LAS CUALES SE LES BRINDA ATENCION EN LAS VETERINARIAS';
CREATE TABLE locality (id bigint(19) NOT NULL AUTO_INCREMENT comment 'NUMERO IDENTIFICADOR DE CADA UNA DE LAS LOCALIDADES DE BOGOTÁ', name varchar(30) NOT NULL comment 'NOMBRE DE CADA UNA DE LAS LOCALIDADES DE BOGOTÁ', PRIMARY KEY (id)) comment='CONTIENE CADA UNA DE LAS LOCALIDADES ASOCIADAS AL BARRIO';
CREATE TABLE consultation (id bigint(19) NOT NULL AUTO_INCREMENT comment 'NUMERO IDENTIFICADOR DE CADA UNA DE LAS CONSULTAS EXISTENTES', id_pet int(10) NOT NULL comment 'ID DE LA MASCOTA A LA CUAL SE LE HA REALIZADO LA CONSULTA', employeeid bigint(19) NOT NULL, id_pet_history bigint(19) NOT NULL, creation_date date NOT NULL comment 'CONTIENE LA FECHA DE LA CONSULTA', reason varchar(300) NOT NULL comment 'CONTIENE EL DETALLE DE LA CONSULTA, LOS HALLAZGOS, RECOMENDACIONES Y ANOTACIONES DEL VETERINARIO', exam_results int(10) comment 'CODIGO DE LOS EXAMENES SOLICITADOS', record int(10) comment 'Antecedentes clinicos que han sido asociados a la historia clinica de la mascota', employee_signature varchar(255), PRIMARY KEY (id)) comment='CONTIENE CADA UNA DE LAS CONSULTAS ASOCIADAS A UNA MASCOTA';
CREATE TABLE exam (id bigint(19) NOT NULL AUTO_INCREMENT comment 'NUMERO IDENTIFICADOR DE CADA UNO DE LOS EXAMENES', name varchar(30) NOT NULL comment 'NOMBRE DEL EXAMEN', PRIMARY KEY (id)) comment='CONTIENE CADA UNO DE LOS EXAMENES QQUE ES POSIBLE REALIZAR EN CADA UNA DE LAS VETERINARIAS';
CREATE TABLE pet (id int(10) NOT NULL AUTO_INCREMENT comment 'NUMERO IDENTIFICADOR DE CADA UNA DE LAS MASCOTAS REGISTRADAS EN EL SISTEMA', id_customer bigint(19) NOT NULL, id_race bigint(19) NOT NULL comment 'RAZA Y ESPECIE DE LA MASCOTA', name varchar(50) NOT NULL comment 'NOMBRE DE LA MASCOTA', birthday date NOT NULL comment 'FECHA DE NACIMIENTO DE LA MASCOTA', microchip varchar(20) UNIQUE, color varchar(10), weight varchar(10), id_vaccine bigint(19), id_conditions bigint(19), id_consultation bigint(19), id_recipe bigint(19), gender varchar(10) NOT NULL, PRIMARY KEY (id)) comment='Contiene la informacion de cada una de las mascotas registradas por los clientes.';
CREATE TABLE consultation_exam (id_consultation bigint(19) NOT NULL, id_exam bigint(19) NOT NULL, PRIMARY KEY (id_consultation, id_exam));
CREATE TABLE product (id bigint(19) NOT NULL AUTO_INCREMENT, Image varchar(255) NOT NULL comment 'CONTIENE EL ENLACE AL ALMACENAMIENTO EXTERNO QUE GUARDA LAS IMAGENES.', price decimal(10, 3) NOT NULL comment 'GUARDA EL PRECIO DEL PRODUCTO EN CUESTION', Stock int(8) NOT NULL comment 'CONTIENE LA CANTIDAD DISPONIBLE DEL PRODUCTO EN LA VETERINARIA', PRIMARY KEY (id)) comment='CONTIENE CADA UNO DE LOS PRODUCTOS (MEDICAMENTOS, ALIMENTOS) OFRECIDOS EN LA VETERINARIA';
CREATE TABLE services (id bigint(19) NOT NULL AUTO_INCREMENT comment 'NUMERO IDENTIFICADOR DE CADA UNO DE LOS SERVICIOS', name varchar(30) NOT NULL comment 'NOMBRE DEL SERVICIO', PRIMARY KEY (id)) comment='CONTIENE CADA UNO DE LOS SERVICIOS QUE PUEDE OFRECER LA VETERINARIA';
CREATE TABLE diary (id bigint(19) NOT NULL AUTO_INCREMENT comment 'NUMERO IDENTIFICADOR DE CADA UNA DE LAS CITAS QUE HAN SIDO AGENDADAS', appointment_date timestamp NOT NULL UNIQUE, id_customer bigint(19) NOT NULL, id_employee bigint(19) NOT NULL, PRIMARY KEY (id)) comment='ENTIDAD QUE CONTIENE CADA UNA DE LAS CITAS EN AGENDA DE LAS VETERINARIAS ALIADAS';
CREATE TABLE services_veterinary (id_service bigint(19) NOT NULL, id_veterinary bigint(19) NOT NULL, PRIMARY KEY (id_service, id_veterinary));
CREATE TABLE species (id bigint(19) NOT NULL AUTO_INCREMENT comment 'NUMERO IDENTIFICADOR DE CADA UNA DE LAS ESPECIES', name varchar(30) NOT NULL comment 'NOMBRE DE LA ESPECIE EN CUESTION', PRIMARY KEY (id)) comment='CONTIENE CADA UNA DE LAS ESPECIES A LAS CUALES SE LES DA TRATAMIENTO EN LAS VETERINARIAS ALIADAS';
CREATE TABLE product_veterinary (id_product bigint(19) NOT NULL, id_veterinary bigint(19) NOT NULL, `Column` int(10), Column2 int(10));
CREATE TABLE customer (id bigint(19) NOT NULL AUTO_INCREMENT, id_user bigint(19) NOT NULL, document_type bigint(19) NOT NULL comment 'CODIGO CON EL TIPO DE DOCUMENTO DEL CLIENTE', neighborhood bigint(19) NOT NULL comment 'CODIGO NUMERICO DEL BARRIO', document_number varchar(15) NOT NULL comment 'Documento de identificacion primaria del usuario', phone_number varchar(10) NOT NULL UNIQUE comment 'NUMERO DE TELEFONO DEL CLIENTE', birthdate date NOT NULL comment 'FECHA DE NACIMIENTO DEL CLIENTE', residence_address varchar(255) NOT NULL, address_detail varchar(30) comment 'DETALLES ADICIONALES DE LA DIRECCION', PRIMARY KEY (id)) comment='Tabla que contiene la informacion general de cada uno de los clientes registrados en el aplicativo.';
CREATE TABLE bill (id bigint(19) NOT NULL AUTO_INCREMENT comment 'LLAVE PRIMARIA DE LA FACTURA, NUMERO DE IDENTIFICACION DE LA FACTURA', id_customer bigint(19) NOT NULL, id_veterinary bigint(19) NOT NULL, id_saved_payment bigint(19) NOT NULL, creation_date date NOT NULL comment 'FECHA DE CREACION DE LA FACTURA', state varchar(100) NOT NULL comment 'ESTADO DE LA FACTURA', subtotal decimal(10, 3) NOT NULL comment 'VALOR DE LOS PRODUCTOS O SERVICIOS', tax decimal(10, 3) NOT NULL comment 'VALOR DE LOS IMPUESTOS LOCALES', total decimal(10, 3) NOT NULL comment 'TOTAL DE LA FACTURA UNA VES SUMADO EL VALOR DE LOS PRODUCTOS E IMPUESTOS', PRIMARY KEY (id)) comment='ENTIDAD LA CUAL SE ENCARGARA DE ALMACENAR LAS PETICIONES AL SISTEMA DE FACTURACION';
CREATE TABLE supplier (id bigint(19) NOT NULL AUTO_INCREMENT, nit varchar(12) NOT NULL comment 'ID QUE IDENTIFFICADA A CADA UNO DE LOS PROVEEDORES', name varchar(25) NOT NULL comment 'NOMBRE DE LA EMPRESA PROVEEDORA', name_employee varchar(120) NOT NULL comment 'NOMBRE DE LA PERSONA A CARGO DE LA EMPRESA PROVEEDORA', address varchar(255) NOT NULL comment 'DIRECCION DE LA EMPRESA PROVEEDORA', phone varchar(10) NOT NULL comment 'NUMERO DE CONTACTO DE LA EMPRESA PROVEEDORA', email varchar(100) NOT NULL UNIQUE comment 'CORREO ELECTRONICO DE LA EMPRESA PROVEEDORA', PRIMARY KEY (id)) comment='ENTIDAD EN LA CUAL SE ALMACENAN LA INFORMACION DE CADA UNO DE LOS PROVEEDORES QUE SURTEN LOS PRODUCTOS';
CREATE TABLE supplier_product (id int(10) NOT NULL AUTO_INCREMENT, id_product bigint(19) NOT NULL, id_supplier bigint(19) NOT NULL, PRIMARY KEY (id));
CREATE TABLE inventory (id bigint(19) NOT NULL AUTO_INCREMENT comment 'ID QUE IDENTIFICA EL INVENTARIO', id_veterinary bigint(19) NOT NULL, stock decimal(9, 2) NOT NULL comment 'CANTIDAD QUE ESTA EN EXISTENCIAS ACTUALMENTE', last_modification date NOT NULL comment 'FECHA EN LA QUE SE REALIZO POR ULTIMA VEZ UN CONTEO', PRIMARY KEY (id)) comment='ENTIDAD QUE GUARDAR LA INFORMACION DEL INVENTARIO EXISTENTE EN LAS CLINICAS VETERINARIAS';
CREATE TABLE subscription (id bigint(19) NOT NULL AUTO_INCREMENT, name varchar(100) NOT NULL comment 'NOMBRE DE CADA UNO DE LOS PLANES DE SUSCRIPCION', description varchar(255) NOT NULL comment 'DESCRIPCION DE AQUELLO QUE INCLUYE EL PLAN Y LAS CONDICIONES DE USO', price decimal(19, 2) NOT NULL comment 'INCLUYE EL COSTO QUE IMPLICA SOBRE EL TOTAL DE VENTAS', state tinyint NOT NULL comment 'ESTADO DEL PLAN EN LA PLATAFORMA EN EL CUAL PUEDE SER ACTIVO, INACTIVO.', PRIMARY KEY (id)) comment='CADA UNO DE LOS PLANES QUE SE INCLUYEN EN LA PLATAFORMA PARA CADA UNA DE LAS CLINICAS';
CREATE TABLE subscription_veterinary (id bigint(19) NOT NULL AUTO_INCREMENT comment 'ID QUE IDENTIFICA CADA UNA DE LAS SUSCRIPCIONES REALIZADAS CON EXITO.', id_subscription bigint(19) NOT NULL comment 'ID DEL PLAN AL CUAL SE REALIZO LA SUSCRIPCION', id_veterinary bigint(19) NOT NULL, state tinyint NOT NULL comment 'ESTADO DE LA SUSCRIPCION ACTIVO, INACTIVO O SUSPENDIDO', last_payment timestamp NOT NULL comment 'FECHA EN QUE SE REALIZO EL ULTIMO PAGO DE LA SUSCRIPCION', next_payment date NOT NULL comment 'FECHA EN LA QUE SE VOLERA A REALIZAR EL COBRO DE LA PLATAFORMA', PRIMARY KEY (id));
CREATE TABLE subscription_payment (id bigint(19) NOT NULL AUTO_INCREMENT comment 'ID DE CADA UNO DE LOS PAGOS POR SUSCRIPCION QUE SE HAYAN REALIZADO', id_subscription_veterinary bigint(19) NOT NULL comment 'ID DE LA SUSCRIPCION A LA QUE SE LE REALIZO UN PAGO', id_payment_method bigint(19) NOT NULL comment 'METODO POR EL CUAL FUE PAGADO LA SUSCRIPCION  (DEBITO, CREDITO, TRANFERENCIA)', amount_paid decimal(19, 2) NOT NULL comment 'PORCENTAJE QUE SE DESCONTO DEL TOTAL DE VENTAS DE LA VETERINARIA', payment_date timestamp NOT NULL comment 'FECHA DEL PAGO REALIZADO A LA SUSCRIPCION', start_billed_period date NOT NULL comment 'FECHA DE INICIO DE LA CUAL SE PAGÓ EL PLAN DE SUJSCRIPCION', end_billed_period date NOT NULL comment 'FECHA EN LA QUE SE TERMINA EL PAGO DE LA SUSCRIPCION', payment_status tinyint NOT NULL comment 'ESTADO EN EL QUE SE ENCUENTRA EL PAGO (RECIBIDO, CANCELADO)', transaction_reference varchar(200) NOT NULL comment 'REFERENCIA DE PAGO QUE SE CREO AL MOMENTO DE PAGAR LA SUSCRIPCION', PRIMARY KEY (id)) comment='TABLA DE HISTORICOS CON CADA UNO DE LOS PAGOS REALIZADOS A UNA SUSCRIPCION';
CREATE TABLE `user` (id bigint(19) NOT NULL AUTO_INCREMENT, login varchar(50) NOT NULL, password_hash varchar(60) NOT NULL, first_name varchar(50), last_name varchar(50), email varchar(191), image_url varchar(256), activated tinyint NOT NULL, lang_key varchar(10), activation_key varchar(20), reset_key varchar(20), created_by varchar(50) NOT NULL, created_date timestamp NULL, reset_date timestamp NULL, last_modified_by varchar(50), `last_modified-date` timestamp NULL, PRIMARY KEY (id));
CREATE TABLE authority (name int(10) NOT NULL AUTO_INCREMENT, PRIMARY KEY (name));
CREATE TABLE authority_user (authorityname int(10) NOT NULL, userid bigint(19) NOT NULL, PRIMARY KEY (authorityname, userid));
CREATE TABLE available_payment_method (id bigint(19) NOT NULL AUTO_INCREMENT, name varchar(100) NOT NULL, description varchar(255), PRIMARY KEY (id));
CREATE TABLE saved_payment_methods (id bigint(19) NOT NULL AUTO_INCREMENT, id_customer bigint(19) NOT NULL comment 'LLAVE FORANEA QUE RELACIONA LOS METODOS DE PAGO CREADOS POR EL CLIENTE', id_available_payment bigint(19) NOT NULL, name varchar(100) NOT NULL, token varchar(255) NOT NULL, expiration_date date NOT NULL, is_main tinyint NOT NULL, PRIMARY KEY (id)) comment='METODOS DE PAGO GUARDADOS POR UN CLIENTE';
CREATE TABLE bill_details (id bigint(19) NOT NULL AUTO_INCREMENT, id_bill bigint(19) NOT NULL, id_product bigint(19) NOT NULL, amount decimal(19, 2) NOT NULL, unit_price decimal(19, 2) NOT NULL, PRIMARY KEY (id)) comment='PRODUCTOS QUE SON CONTENIDOS EN UNA FACTURA';
CREATE TABLE pet_history (id bigint(19) NOT NULL AUTO_INCREMENT, id_pet bigint(19) NOT NULL, id_conditions bigint(19) NOT NULL, id_recipes bigint(19) NOT NULL, PRIMARY KEY (id)) comment='HISTORIAL QUE REUNE LA INFORMACION DE LA MASCOTA';
CREATE TABLE vaccine (id bigint(19) NOT NULL AUTO_INCREMENT, id_indications bigint(19) NOT NULL, name varchar(100) NOT NULL, application_date date NOT NULL, next_application date NOT NULL, summary varchar(255) NOT NULL, PRIMARY KEY (id));
CREATE TABLE certificate (id bigint(19) NOT NULL AUTO_INCREMENT, id_vaccine bigint(19) NOT NULL, name varchar(120) NOT NULL, id_pet bigint(19) NOT NULL, creation_date timestamp NOT NULL, url varchar(255) NOT NULL, PRIMARY KEY (id));
CREATE TABLE indication (id bigint(19) NOT NULL AUTO_INCREMENT, name varchar(100) NOT NULL, description varchar(255) NOT NULL, PRIMARY KEY (id));
CREATE TABLE `condition` (id bigint(19) NOT NULL AUTO_INCREMENT, name varchar(255) NOT NULL, description varchar(255) NOT NULL, PRIMARY KEY (id));
CREATE TABLE recipe (id bigint(19) NOT NULL AUTO_INCREMENT, name varchar(100) NOT NULL, description varchar(255) NOT NULL, creation_date timestamp NOT NULL, expiration_date timestamp NOT NULL, PRIMARY KEY (id));
CREATE TABLE pet_history_vaccine (id_pet_history bigint(19) NOT NULL, id_vaccine bigint(19) NOT NULL, PRIMARY KEY (id_pet_history, id_vaccine));
CREATE TABLE condition_pet_history (conditionid bigint(19) NOT NULL, pet_historyid bigint(19) NOT NULL, PRIMARY KEY (conditionid, pet_historyid));
CREATE TABLE pet_history_recipe (pet_historyid bigint(19) NOT NULL, recipeid bigint(19) NOT NULL, PRIMARY KEY (pet_historyid, recipeid));
CREATE TABLE admin (id bigint(19) NOT NULL AUTO_INCREMENT, id_user bigint(19) NOT NULL, description varchar(255), PRIMARY KEY (id));
CREATE TABLE entrancy (id int(10) NOT NULL AUTO_INCREMENT, supplier_productid int(10) NOT NULL, quantity int(10) NOT NULL, date_entrancy timestamp NOT NULL, PRIMARY KEY (id));
